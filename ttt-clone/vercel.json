{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/post/:slug", "destination": "/post/:slug.html" },
    { "source": "/course/:slug", "destination": "/course/:slug.html" },
    { "source": "/:page", "destination": "/:page.html" }
  ]
}
